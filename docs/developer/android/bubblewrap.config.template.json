        {
          "src": "https://lifesh.app/pwa/icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Talk with Steward",
      "shortName": "Steward",
      "url": "/learn",
      "icons": [
        {
          "src": "https://lifesh.app/pwa/icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "fallbackType": "customtabs",
  "features": {
    "playBilling": false,
    "locationDelegation": false
  }
}
