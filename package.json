{
  "name": "lifeschool",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "app.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "install": "node scripts/install.mjs",
    "dev": "tsx --env-file=platform/steward-app/.env.local platform/steward-app/src/server/local-server.ts",
    "build": "node platform/steward-app/scripts/build.mjs",
    "start": "node app.js",
    "typecheck": "tsc -p platform/steward-app/tsconfig.json --noEmit",
    "test": "vitest run --root platform/steward-app"
  },
  "dependencies": {
    "express": "^5.1.0",
    "nodemailer": "^9.0.3",
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^8.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
